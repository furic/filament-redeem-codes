{
    "name": "furic/filament-redeem-codes",
    "description": "Filament v5 plugin for batch-issued, multi-reward redeem codes — for games, event rewards and player compensation.",
    "keywords": [
        "filament",
        "filamentphp",
        "laravel",
        "redeem code",
        "promo code",
        "voucher",
        "game",
        "reward"
    ],
    "homepage": "https://github.com/furic/filament-redeem-codes",
    "license": "MIT",
    "authors": [
        {
            "name": "Richard Fu",
            "email": "fur@richardfu.net",
            "homepage": "https://www.richardfu.net",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Furic\\FilamentRedeemCodes\\": "src/",
            "Furic\\FilamentRedeemCodes\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Furic\\FilamentRedeemCodes\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Furic\\FilamentRedeemCodes\\FilamentRedeemCodesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
